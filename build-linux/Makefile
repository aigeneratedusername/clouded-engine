	$(MAKE) $(MAKESILENT) -f CMakeFiles/engine.dir/build.make CMakeFiles/engine.dir/vendor/tomlc17/tomlc17.c.o
.PHONY : vendor/tomlc17/tomlc17.c.o

vendor/tomlc17/tomlc17.i: vendor/tomlc17/tomlc17.c.i
.PHONY : vendor/tomlc17/tomlc17.i

# target to preprocess a source file
vendor/tomlc17/tomlc17.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/engine.dir/build.make CMakeFiles/engine.dir/vendor/tomlc17/tomlc17.c.i
.PHONY : vendor/tomlc17/tomlc17.c.i

vendor/tomlc17/tomlc17.s: vendor/tomlc17/tomlc17.c.s
.PHONY : vendor/tomlc17/tomlc17.s

# target to generate assembly for a file
vendor/tomlc17/tomlc17.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/engine.dir/build.make CMakeFiles/engine.dir/vendor/tomlc17/tomlc17.c.s
.PHONY : vendor/tomlc17/tomlc17.c.s

